# E2E test environment — copy to project root as .env.e2e and fill in values
# NEVER commit .env.e2e — it is gitignored

# Target app (local dev server or staging URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to same URL to enable gateway mode tests
PRISM_GATEWAY_URL=http://localhost:3000

# Supabase (service role — for seed/teardown only, never send to clients)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# Provider API keys (used in analytics mode directly + stored encrypted for gateway mode)
OPENAI_API_KEY=sk-...

# AES-256 key for provider key encryption (must match ENCRYPTION_SECRET in apps/web/.env.local)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=your-64-hex-char-encryption-secret

# Tinybird (for verify step — queries pipes directly)
TINYBIRD_API_URL=https://api.tinybird.co
TINYBIRD_ADMIN_TOKEN=p.eyJ...

# Guards the /api/test/reset endpoint — any random secret string
PRISM_TEST_SECRET=e2e-reset-secret-change-me
