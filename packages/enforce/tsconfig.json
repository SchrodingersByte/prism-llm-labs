{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "lib":              ["ES2020"],
    "strict":           true,
    "declaration":      true,
    "outDir":           "./dist",
    "rootDir":          "./src",
    "skipLibCheck":     true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
