{
  "name": "@prism-llm-labs/sdk",
  "version": "0.5.0",
  "description": "TypeScript SDK for Prism LLM observability",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "prism-evals": "./bin/prism-evals.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@google/generative-ai": "^0.24.1",
    "openai": ">=1.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@google/generative-ai": "^0.24.1",
    "@types/node": "^20",
    "openai": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5",
    "vitest": "^1.0.0"
  }
}
