DESCRIPTION >
    Session cost distribution: P50, P90, P99 and average cost per session.
    Aggregates llm_events_filtered by session_id (from tags) to compute
    per-session totals, then derives percentiles across all sessions.

NODE sessions_agg
SQL >
    %
    SELECT
        tags['session_id']            AS session_id,
        sum(cost_usd)                 AS session_cost_usd,
        count()                       AS llm_calls,
        sum(input_tokens + output_tokens + cached_tokens) AS total_tokens
    FROM llm_events_filtered
    WHERE org_id    = {{ String(org_id, '') }}
      AND timestamp >= {{ DateTime(from_date, '2024-01-01 00:00:00') }}
      AND timestamp <= {{ DateTime(to_date,   '2099-01-01 00:00:00') }}
      AND ({{ String(project_id, '') }} = '' OR project_id = {{ String(project_id, '') }})
      {% if defined(project_ids) and project_ids != '' %}
      AND project_id IN {{ Array(project_ids, 'String') }}
      {% end %}
      AND ({{ String(environment, '') }} = '' OR environment = {{ String(environment, '') }})
      AND tags['session_id'] != ''
    GROUP BY session_id

NODE endpoint
SQL >
    SELECT
        quantile(0.50)(session_cost_usd)  AS p50_cost_usd,
        quantile(0.90)(session_cost_usd)  AS p90_cost_usd,
        quantile(0.99)(session_cost_usd)  AS p99_cost_usd,
        avg(session_cost_usd)             AS avg_cost_usd,
        count()                           AS session_count,
        sum(session_cost_usd)             AS total_cost_usd,
        avg(llm_calls)                    AS avg_calls_per_session,
        avg(total_tokens)                 AS avg_tokens_per_session
    FROM sessions_agg
    WHERE session_id != ''

TYPE endpoint
