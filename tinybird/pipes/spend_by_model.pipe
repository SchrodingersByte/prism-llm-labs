NODE aggregated
SQL >
  %
  SELECT
      model,
      provider,
      sum(cost_usd)       AS total_cost_usd,
      count()             AS requests,
      sum(input_tokens)   AS input_tokens,
      sum(output_tokens)  AS output_tokens,
      sum(cached_tokens)  AS cached_tokens,
      countIf(status_code >= 400) AS error_count,
      avg(latency_ms)     AS avg_latency_ms
  FROM llm_events_filtered
  WHERE org_id    = {{ String(org_id, '') }}
    AND timestamp >= {{ DateTime(from_date, '2024-01-01 00:00:00') }}
    AND timestamp <= {{ DateTime(to_date,   '2099-01-01 00:00:00') }}
    AND ({{ String(project_id, '') }} = '' OR project_id = {{ String(project_id, '') }})
    {% if defined(project_ids) and project_ids != '' %}
    AND project_id IN {{ Array(project_ids, 'String') }}
    {% end %}
    AND ({{ String(environment, '') }} = '' OR environment = {{ String(environment, '') }})
  GROUP BY model, provider

NODE endpoint
TYPE endpoint
SQL >
  SELECT
      model,
      provider,
      total_cost_usd,
      requests,
      input_tokens,
      output_tokens,
      cached_tokens,
      avg_latency_ms,
      error_count,
      if(requests > 0, total_cost_usd / requests, 0)                             AS avg_cost_per_request,
      if(input_tokens > 0, output_tokens / input_tokens, 0)                      AS output_input_ratio,
      if(input_tokens + cached_tokens > 0,
         cached_tokens / (input_tokens + cached_tokens), 0)                      AS cache_hit_rate,
      if(total_cost_usd > 0,
         (input_tokens + output_tokens) / total_cost_usd, 0)                     AS tokens_per_dollar,
      if(requests > 0, error_count / requests, 0)                                AS error_rate
  FROM aggregated
  ORDER BY total_cost_usd DESC
