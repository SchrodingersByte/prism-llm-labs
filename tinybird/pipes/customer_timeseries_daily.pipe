DESCRIPTION >
    Daily cost time-series for a single customer. Used by the dashboard customer
    detail drawer to render the spend sparkline chart.

NODE endpoint
TYPE endpoint
SQL >
    %
    SELECT
        toDate(timestamp)     AS date,
        sum(cost_usd)         AS cost_usd,
        count()               AS requests,
        sum(input_tokens + output_tokens + cached_tokens) AS total_tokens
    FROM llm_events_filtered
    WHERE org_id    = {{ String(org_id, '') }}
      AND timestamp >= {{ DateTime(from_date, '2024-01-01 00:00:00') }}
      AND timestamp <= {{ DateTime(to_date,   '2099-01-01 00:00:00') }}
      AND tags['customer_id'] = {{ String(customer_id, '') }}
    GROUP BY date
    ORDER BY date ASC
