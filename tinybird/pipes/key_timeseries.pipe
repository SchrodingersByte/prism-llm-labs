NODE endpoint
TYPE endpoint
SQL >
  %
  SELECT
      toDate(timestamp)               AS date,
      api_key_id,
      sum(cost_usd)                   AS cost_usd,
      count()                         AS requests,
      sum(input_tokens + output_tokens) AS total_tokens,
      sum(image_tokens)               AS image_tokens,
      sum(audio_tokens)               AS audio_tokens
  FROM llm_events_filtered
  WHERE org_id    = {{ String(org_id, '') }}
    AND api_key_id = {{ String(api_key_id, '') }}
    AND timestamp >= {{ DateTime(from_date, '2024-01-01 00:00:00') }}
    AND timestamp <= {{ DateTime(to_date,   '2099-01-01 00:00:00') }}
  GROUP BY date, api_key_id
  ORDER BY date ASC
