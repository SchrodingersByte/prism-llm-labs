NODE endpoint
TYPE endpoint
SQL >
  %
  -- Queries llm_events_filtered (v2, Map tags, GDPR-erased events removed).
  -- tags column is Map(String,String) in v2 — use Map accessor, not JSONExtractString.
  SELECT
      tags['session_id']                                                     AS session_id,
      min(timestamp)                                                         AS started_at,
      max(timestamp)                                                         AS last_seen_at,
      dateDiff('second', min(timestamp), max(timestamp))                     AS duration_seconds,
      count()                                                                AS llm_calls,
      sum(cost_usd)                                                          AS llm_cost_usd,
      sum(input_tokens + output_tokens)                                      AS total_tokens,
      avg(latency_ms)                                                        AS avg_latency_ms,
      groupUniqArray(model)                                                  AS models_used,
      countIf(tags['tool_calls_count'] != '')                                AS calls_with_mcp,
      length(groupUniqArray(tags['tool_names']))                             AS distinct_tool_count,
      any(project_id)                                                        AS project_id,
      any(user_id)                                                           AS user_id
  FROM llm_events_filtered
  WHERE org_id    = {{ String(org_id, '') }}
    AND timestamp >= {{ DateTime(from_date, '2024-01-01 00:00:00') }}
    AND timestamp <= {{ DateTime(to_date,   '2099-01-01 00:00:00') }}
    AND ({{ String(environment, '') }} = '' OR environment = {{ String(environment, '') }})
    AND tags['session_id'] != ''
    {% if defined(project_id) and project_id != '' %}
    AND project_id = {{ String(project_id, '') }}
    {% end %}
  GROUP BY session_id
  ORDER BY started_at DESC
  LIMIT {{ Int32(limit, 100) }}
