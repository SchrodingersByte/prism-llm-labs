DESCRIPTION >
    Online-eval quality grouped by scorer_type (PRD-1): average score, pass rate,
    and volume per scorer (rubric / faithfulness / answer_relevancy /
    context_precision / context_recall / toxicity / hallucination). Optionally
    filtered by model / project. Powers the Quality dashboard "by scorer" view.

NODE agg
SQL >
    %
    SELECT
        scorer_type,
        count()      AS scores,
        avg(score)   AS avg_score_raw,
        sum(passed)  AS passed_count
    FROM eval_score_events
    WHERE org_id = {{ String(org_id, '') }}
      AND scored_at >= {{ DateTime(from_date, '2024-01-01 00:00:00') }}
      AND scored_at <= {{ DateTime(to_date,   '2099-01-01 00:00:00') }}
      AND ({{ String(project_id, '') }} = '' OR project_id = {{ String(project_id, '') }})
      AND ({{ String(model, '') }} = '' OR model = {{ String(model, '') }})
    GROUP BY scorer_type

NODE endpoint
TYPE endpoint
SQL >
    SELECT
        scorer_type,
        scores,
        round(avg_score_raw, 4)                  AS avg_score,
        if(scores > 0, passed_count / scores, 0) AS pass_rate
    FROM agg
    ORDER BY scores DESC
