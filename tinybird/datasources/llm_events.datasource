SCHEMA >
    `event_id`        String                 `json:$.event_id`,
    `timestamp`       DateTime64(3)          `json:$.timestamp`,
    `org_id`          String                 `json:$.org_id`,
    `project_id`      String                 `json:$.project_id`,
    `project_name`    String                 `json:$.project_name`,
    `api_key_id`      String                 `json:$.api_key_id`,
    `user_id`         String                 `json:$.user_id`,
    `environment`     LowCardinality(String) `json:$.environment`,
    `provider`        LowCardinality(String) `json:$.provider`,
    `model`           LowCardinality(String) `json:$.model`,
    `input_tokens`    UInt32                 `json:$.input_tokens`,
    `output_tokens`   UInt32                 `json:$.output_tokens`,
    `cached_tokens`   UInt32                 `json:$.cached_tokens`,
    `image_tokens`    UInt32                 `json:$.image_tokens`,
    `audio_tokens`    UInt32                 `json:$.audio_tokens`,
    `text_tokens`     UInt32                 `json:$.text_tokens`,
    `modalities`      String                 `json:$.modalities`,
    `cost_usd`        Float64                `json:$.cost_usd`,
    `latency_ms`      UInt32                 `json:$.latency_ms`,
    `ttft_ms`         UInt32                 `json:$.ttft_ms`,
    `status_code`     UInt16                 `json:$.status_code`,
    `request_id`      String                 `json:$.request_id`,
    `trace_id`        String                 `json:$.trace_id`,
    `span_id`         String                 `json:$.span_id`,
    `parent_span_id`  String                 `json:$.parent_span_id`,
    `session_id`      String                 `json:$.session_id`,
    `tags`            Map(String, String)    `json:$.tags`,
    `attributes`      String                 `json:$.attributes`,
    `key_type`        LowCardinality(String) `json:$.key_type`,
    `prism_cache_hit` UInt8                  `json:$.prism_cache_hit`,
    `ttl_days`        UInt16                 `json:$.ttl_days`,
    `reasoning_tokens` UInt32                `json:$.reasoning_tokens`

ENGINE "MergeTree"
ENGINE_PARTITION_KEY "toYYYYMM(timestamp)"
ENGINE_SORTING_KEY "org_id, project_id, trace_id, timestamp"
ENGINE_TTL "toDateTime(timestamp) + INTERVAL ttl_days DAY"
